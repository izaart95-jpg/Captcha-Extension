{
  "manifest_version": 3,
  "name": "Arena reCAPTCHA Harvester",
  "version": "2.1.0",
  "description": "Harvests reCAPTCHA v2/v3 tokens on arena.ai and sends them to a local server.",

  "permissions": [
    "storage",
    "cookies",
    "tabs",
    "scripting",
    "webNavigation"
  ],

  "host_permissions": [
    "https://arena.ai/*",
    "http://localhost/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://arena.ai/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
